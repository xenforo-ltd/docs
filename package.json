{
  "name": "@xenforo-ltd/docs",
  "description": "XenForo Documentation",
  "author": "XenForo Ltd",
  "homepage": "https://docs.xenforo.com",
  "bugs": {
    "url": "https://github.com/xenforo-ltd/docs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xenforo-ltd/docs.git"
  },
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "docusaurus:build": "docusaurus build",
    "docusaurus:clear": "docusaurus clear",
    "docusaurus:clean-api-docs": "docusaurus clean-api-docs all",
    "docusaurus:gen-api-docs": "docusaurus gen-api-docs all",
    "docusaurus:serve": "docusaurus serve",
    "docusaurus:start": "docusaurus start",
    "docusaurus:swizzle": "docusaurus swizzle",
    "docusaurus:write-heading-ids": "docusaurus write-heading-ids",
    "eslint": "eslint",
    "eslint:fix": "eslint --fix",
    "prettier": "prettier",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "spellcheck": "cspell lint --config cspell.json --no-progress \"docs/**/*.{md,mdx}\" \"README.md\" \"CONTRIBUTING.md\"",
    "spellcheck:changed": "git diff --name-only --diff-filter=ACMRT HEAD~1 | grep -E '\\.(md|mdx)$' | xargs -r cspell lint --config cspell.json --no-progress"
  },
  "dependencies": {
    "@docusaurus/core": "~3.10.1",
    "@docusaurus/faster": "~3.10.1",
    "@docusaurus/plugin-client-redirects": "~3.10.1",
    "@docusaurus/plugin-content-docs": "~3.10.1",
    "@docusaurus/preset-classic": "~3.10.1",
    "@docusaurus/theme-common": "~3.10.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "~5.0.2",
    "docusaurus-theme-openapi-docs": "~5.0.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@docusaurus/eslint-plugin": "^3.10.1",
    "@docusaurus/module-type-aliases": "~3.10.1",
    "@docusaurus/tsconfig": "~3.10.1",
    "@docusaurus/types": "~3.10.1",
    "@eslint/core": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "cspell": "~10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-mdx": "^3.8.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "~3.8.4",
    "remark-frontmatter": "^5.0.0",
    "remark-lint": "^10.0.1",
    "remark-lint-emphasis-marker": "^4.0.1",
    "remark-lint-heading-increment": "^4.0.1",
    "remark-lint-list-item-spacing": "^5.0.1",
    "remark-lint-maximum-line-length": "^4.1.1",
    "remark-mdx": "^3.1.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-markdown-style-guide": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  }
}